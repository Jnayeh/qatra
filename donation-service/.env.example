# Database
DB_URL=jdbc:postgresql://localhost:5432/qatra
DB_USERNAME=qatra
DB_PASSWORD=qatra

# JWT
JWT_SECRET=QatraSecretKeyMustBeAtLeast256BitsLongForHS256AlgorithmMinimum
JWT_EXPIRATION_MS=86400000

# Server
SERVER_PORT=8080

# CORS
CORS_ALLOWED_ORIGINS=*
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=*
CORS_MAX_AGE=3600
CORS_PATH_PATTERN=/api/**

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_APPOINTMENT_EVENTS=appointment-events
KAFKA_TOPIC_APPOINTMENT_EVENTS_PARTITIONS=3
KAFKA_TOPIC_APPOINTMENT_EVENTS_REPLICAS=1
KAFKA_TOPIC_EMERGENCY_EVENTS=emergency-events
KAFKA_TOPIC_EMERGENCY_EVENTS_PARTITIONS=3
KAFKA_TOPIC_EMERGENCY_EVENTS_REPLICAS=1
KAFKA_TOPIC_AUDIT_EVENTS=audit-events
KAFKA_TOPIC_AUDIT_EVENTS_PARTITIONS=2
KAFKA_TOPIC_AUDIT_EVENTS_REPLICAS=1

# Slot generation
SLOT_GENERATION_CRON=0 0 0 */21 * *
SLOT_GENERATION_LOOKAHEAD_DAYS=21
SLOT_GENERATION_DEFAULT_PERIOD_MINUTES=60
SLOT_GENERATION_TIMEZONE=UTC

# Emergency
EMERGENCY_EXPIRATION_MINUTES=180
ESCALATION_AFTER_MINUTES=30
EMERGENCY_ESCALATION_RADIUS_INCREMENT=10
EMERGENCY_MONITORING_INTERVAL_MS=300000

# Eligibility
ELIGIBILITY_RESTORATION_INTERVAL_MS=3600000

# Questionnaire
QUESTIONNAIRE_PERMANENT_RESTRICTION_KEYWORDS=insulin,chemo,immunosuppressant

# Notification channels per event type
NOTIFICATION_EMERGENCY_CHANNELS=IN_APP
NOTIFICATION_APPOINTMENT_CHANNELS=IN_APP
NOTIFICATION_ELIGIBILITY_CHANNELS=IN_APP,EMAIL
NOTIFICATION_PASSWORD_RESET_CHANNELS=IN_APP,EMAIL
NOTIFICATION_EMAIL_VERIFICATION_CHANNELS=IN_APP,EMAIL
NOTIFICATION_PROFILE_COMPLETION_CHANNELS=IN_APP

# Super admin seed (leave empty to skip seeding)
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PHONE=
SUPER_ADMIN_PASSWORD=

# Cache
SPRING_CACHE_TYPE=simple
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_TIMEOUT=2000ms
CACHE_DEFAULT_TTL=300

# DevTools
DEVTOOLS_RESTART=true
DEVTOOLS_LIVERELOAD=true
